v class=\"rhcsa-timeline\">\n\n      <div class=\"rhcsa-step\">\n        <div class=\"rhcsa-dot\"></div>\n        <div class=\"rhcsa-content\">\n          <h4>Set Up Your Lab Environment</h4>\n          <p>Install RHEL 9 in a VM or spin up a cloud instance. Learn how to access the terminal, configure a static IP, and navigate your first shell session.</p>\n          <span class=\"rhcsa-duration\">⏱ Week 1</span>\n        </div>\n      </div>\n\n      <div class=\"rhcsa-step\">\n        <div class=\"rhcsa-dot\"></div>\n        <div class=\"rhcsa-content\">\n          <h4>CLI Fluency &amp; Filesystem Mastery</h4>\n          <p>Get comfortable with file operations, searching, redirection, and permissions. Practice with real-world scenarios, not contrived exercises.</p>\n          <span class=\"rhcsa-duration\">⏱ Weeks 2–3</span>\n        </div>\n      </div>\n\n      <div class=\"rhcsa-step\">\n        <div class=\"rhcsa-dot\"></div>\n        <div class=\"rhcsa-content\">\n          <h4>RHEL Administration Deep-Dive</h4>\n          <p>Manage packages, users, services, and storage. Configure a multi-disk LVM layout and understand how RHEL boots and recovers.</p>\n          <span class=\"rhcsa-duration\">⏱ Weeks 4–6</span>\n        </div>\n      </div>\n\n      <div class=\"rhcsa-step\">\n        <div class=\"rhcsa-dot\"></div>\n        <div class=\"rhcsa-content\">\n          <h4>Harden &amp; Automate Your Server</h4>\n          <p>Apply SELinux policies, configure a stateful firewall, and write Bash automation scripts that run reliably in production.</p>\n          <span class=\"rhcsa-duration\">⏱ Weeks 7–9</span>\n        </div>\n      </div>\n\n      <div class=\"rhcsa-step\">\n        <div class=\"rhcsa-dot\" style=\"background: #f59e0b; box-shadow: 0 0 0 6px var(--page-bg), 0 0 0 8px rgba(245,158,11,0.2);\"></div>\n        <div class=\"rhcsa-content\">\n          <h4>RHCSA Exam Ready</h4>\n          <p>Complete timed mock exams that mirror the real EX200. Get personalised feedback and targeted revision until you're exam-confident.</p>\n          <span class=\"rhcsa-duration\" style=\"color: #f59e0b; border-color: rgba(245,158,11,0.3);\">🏆 Week 10 — Exam Simulation</span>\n        </div>\n      </div>\n\n    </div>\n  </section>\n  \n  \n <div class=\"enrollment-badge\">\n    <span class=\"blink-dot\"></span> Enrollment Open\n  </div>\n\n  <div class=\"wd-cta content-section\" style=\"margin-top: 0; margin-bottom: 5rem;\">\n    <h2>Ready to Own the Command Line?</h2>\n    <p>\n      Join professionals who've levelled up their Linux skills with a \n      curriculum built by practitioners, not theorists.\n    </p>\n    <div class=\"wd-cta-actions\">\n      <a href=\"/contact.qmd\" class=\"btn-primary-wd\">Start Learning →</a>\n    </div>\n  </div>\n\n</div>\n```\n"},"formats":{"html":{"identifier":{"display-name":"HTML","target-format":"html","base-format":"html"},"execute":{"fig-width":7,"fig-height":5,"fig-format":"retina","fig-dpi":96,"df-print":"default","error":false,"eval":true,"cache":null,"freeze":"auto","echo":true,"output":true,"warning":true,"include":true,"keep-md":false,"keep-ipynb":false,"ipynb":null,"enabled":null,"daemon":null,"daemon-restart":false,"debug":false,"ipynb-filters":[],"ipynb-shell-interactivity":null,"plotly-connected":true,"engine":"markdown"},"render":{"keep-tex":false,"keep-typ":false,"keep-source":false,"keep-hidden":false,"prefer-html":false,"output-divs":true,"output-ext":"html","fig-align":"default","fig-pos":null,"fig-env":null,"code-fold":"none","code-overflow":"scroll","code-link":false,"code-line-numbers":false,"code-tools":false,"tbl-colwidths":"auto","merge-includes":true,"inline-includes":false,"preserve-yaml":false,"latex-auto-mk":true,"latex-auto-install":true,"latex-clean":true,"latex-min-runs":1,"latex-max-runs":10,"latex-makeindex":"makeindex","latex-makeindex-opts":[],"latex-tlmgr-opts":[],"latex-input-paths":[],"latex-output-dir":null,"link-external-icon":false,"link-external-ne